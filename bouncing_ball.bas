10  REM *** BOUNCING BALL ***
20  REM *** APPLE II GR MODE ***
30  GR
40  X = 20: Y = 20
50  DX = 1: DY = 1
60  C = 1
100  REM *** MAIN LOOP ***
110  COLOR= 0
120  PLOT X,Y
130  X = X + DX
140  Y = Y + DY
150  IF X < 1 OR X > 38 THEN DX =  - DX: C = C + 1: IF C > 15 THEN C = 1
160  IF Y < 1 OR Y > 38 THEN DY =  - DY: C = C + 1: IF C > 15 THEN C = 1
170  IF X < 0 THEN X = 0
180  IF X > 39 THEN X = 39
190  IF Y < 0 THEN Y = 0
200  IF Y > 39 THEN Y = 39
210  COLOR= C
220  PLOT X,Y
230  FOR D = 1 TO 20: NEXT D
240  GOTO 100
