5  REM *** PIPOPIPETTE HGR ***
10  GOSUB 9000: REM INIT
15  HCOLOR=3: HGR : HGR2
20  CP = 1: REM CURRENT VISIBLE PAGE
30  POKE -16302,0: REM FULL HGR

100 REM *** MAIN LOOP ***
110 GOSUB 2000: REM INPUTS
120 GOSUB 3000: REM DRAW HIDDEN
130 GOSUB 4000: REM FLIP
140 IF FI = 1 THEN GOTO 500
150 IF TR = 0 THEN GOTO 100
160 GOSUB 5000: REM AI
170 GOTO 100

500 REM *** FIN DE JEU ***
510 GOSUB 6000: REM AFFICHE GAGNANT
520 GET A$: END

1000 REM *** DESSIN ECRAN COMPLET ***
1010 G = 3 - CP: GOSUB 8000: REM HIDDEN PAGE
1020 CALL 62450: REM CLEAR PAGE
1030 HCOLOR=3
1040 FOR I = 0 TO 5: FOR J = 0 TO 5
1050 X = 60 + I * 30: Y = 20 + J * 25
1060 HPLOT X-1,Y TO X+1,Y: HPLOT X,Y-1 TO X,Y+1
1070 NEXT J: NEXT I
1080 HCOLOR=1: X = 10: Y = 165: D = PS: GOSUB 7000: REM SCORE J
1090 HCOLOR=6: X = 200: Y = 165: D = OS: GOSUB 7000: REM SCORE O
1100 FOR I = 0 TO 4: FOR J = 0 TO 5: IF LH(I,J) THEN GOSUB 1300
1110 NEXT J: NEXT I
1120 FOR I = 0 TO 5: FOR J = 0 TO 4: IF LV(I,J) THEN GOSUB 1400
1130 NEXT J: NEXT I
1140 FOR I = 0 TO 4: FOR J = 0 TO 4: IF BX(I,J) THEN GOSUB 1500
1150 NEXT J: NEXT I
1160 RETURN

1300 HCOLOR=3: X1 = 60+I*30: Y1 = 20+J*25: X2 = X1+30: HPLOT X1,Y1 TO X2,Y1: RETURN
1400 HCOLOR=3: X1 = 60+I*30: Y1 = 20+J*25: Y2 = Y1+25: HPLOT X1,Y1 TO X1,Y2: RETURN
1500 C = BX(I,J): HCOLOR = 1: IF C = 2 THEN HCOLOR = 6
1510 X1 = 60+I*30+3: Y1 = 20+J*25+3: X2 = X1+24: Y2 = Y1+19
1520 FOR YY = Y1 TO Y2: HPLOT X1,YY TO X2,YY: NEXT YY: RETURN

2000 REM *** INPUTS ***
2010 PX = PDL(0): PY = PDL(1)
2020 B1 = PEEK(-16286): IF B1 > 127 THEN IF BT = 0 THEN MD = 1 - MD: BT = 1
2030 IF B1 <= 127 THEN BT = 0
2040 IF MD = 0 THEN CX = INT(PX/51.1): CY = INT(PY/42.6): IF CX>4 THEN CX=4
2045 IF MD = 0 AND CY>5 THEN CY=5
2050 IF MD = 1 THEN CX = INT(PX/42.6): CY = INT(PY/51.1): IF CX>5 THEN CX=5
2055 IF MD = 1 AND CY>4 THEN CY=4
2060 B0 = PEEK(-16287): IF B0 > 127 THEN IF BL = 0 THEN GOSUB 2500: BL = 1
2070 IF B0 <= 127 THEN BL = 0
2080 RETURN

2500 REM *** PLACER ***
2510 IF MD = 0 THEN IF LH(CX,CY) THEN RETURN
2520 IF MD = 1 THEN IF LV(CX,CY) THEN RETURN
2530 IF MD = 0 THEN LH(CX,CY) = 1
2540 IF MD = 1 THEN LV(CX,CY) = 1
2550 GOSUB 3500: IF NB = 0 THEN TR = 1
2560 RETURN

3000 REM *** DESSIN CURSEUR ***
3010 GOSUB 1000: REM REDRAW ALL ON HIDDEN
3020 HCOLOR = 3: IF MD = 0 THEN X1 = 60+CX*30: Y1 = 20+CY*25: X2 = X1+30: Y2 = Y1
3030 IF MD = 1 THEN X1 = 60+CX*30: Y1 = 20+CY*25: X2 = X1: Y2 = Y1+25
3040 HPLOT X1,Y1 TO X2,Y2: RETURN

4000 REM *** FLIP ***
4010 CP = 3 - CP: IF CP = 1 THEN POKE -16300,0: RETURN
4020 POKE -16299,0: RETURN

3500 REM *** BOX CHECK ***
3510 NB = 0: IF MD = 0 THEN GOSUB 3600
3520 IF MD = 1 THEN GOSUB 3700
3530 RETURN

3600 IF CY > 0 THEN IF LH(CX,CY-1) AND LV(CX,CY-1) AND LV(CX+1,CY-1) THEN IF BX(CX,CY-1)=0 THEN BX(CX,CY-1)=TR+1: NB=NB+1: GOSUB 3900
3610 IF CY < 5 THEN IF LH(CX,CY+1) AND LV(CX,CY) AND LV(CX+1,CY) THEN IF BX(CX,CY)=0 THEN BX(CX,CY)=TR+1: NB=NB+1: GOSUB 3900
3620 RETURN

3700 IF CX > 0 THEN IF LV(CX-1,CY) AND LH(CX-1,CY) AND LH(CX-1,CY+1) THEN IF BX(CX-1,CY)=0 THEN BX(CX-1,CY)=TR+1: NB=NB+1: GOSUB 3900
3710 IF CX < 5 THEN IF LV(CX+1,CY) AND LH(CX,CY) AND LH(CX,CY+1) THEN IF BX(CX,CY)=0 THEN BX(CX,CY)=TR+1: NB=NB+1: GOSUB 3900
3720 RETURN

3900 IF TR = 0 THEN PS = PS + 1: GOTO 3920
3910 OS = OS + 1
3920 IF (PS + OS) = 25 THEN FI = 1
3930 RETURN

5000 REM *** AI ***
5100 D = INT(RND(1)*2): X = INT(RND(1)*6): Y = INT(RND(1)*6)
5110 IF D = 0 AND (X > 4 OR LH(X,Y)) THEN GOTO 5100
5120 IF D = 1 AND (Y > 4 OR LV(X,Y)) THEN GOTO 5100
5130 MD = D: CX = X: CY = Y: IF MD = 0 THEN LH(CX,CY) = 1
5140 IF MD = 1 THEN LV(CX,CY) = 1
5150 GOSUB 3500: IF NB > 0 THEN IF FI=0 THEN GOTO 5000: REM REJOUE
5160 TR = 0: RETURN

6000 REM *** GAGNANT ***
6100 G = CP: GOSUB 8000: HCOLOR = 3
6110 X = 100: Y = 90: IF PS >= OS THEN GOSUB 7500: REM J GAGNE
6120 IF OS > PS THEN GOSUB 7600: REM O GAGNE
6130 RETURN

7000 REM *** DRAW SCORE D AT X,Y ***
7010 D1 = INT(D/10): D2 = D - D1 * 10
7020 DD = D1: GOSUB 7100: X = X + 8: DD = D2: GOSUB 7100: RETURN
7100 IF DD = 0 THEN HPLOT X,Y TO X+5,Y TO X+5,Y+8 TO X,Y+8 TO X,Y: RETURN
7110 IF DD = 1 THEN HPLOT X+3,Y TO X+3,Y+8: RETURN
7120 IF DD = 2 THEN HPLOT X,Y TO X+5,Y TO X+5,Y+4 TO X,Y+4 TO X,Y+8 TO X+5,Y+8: RETURN
7130 IF DD = 3 THEN HPLOT X,Y TO X+5,Y TO X+5,Y+8 TO X,Y+8: HPLOT X,Y+4 TO X+5,Y+4: RETURN
7140 IF DD = 4 THEN HPLOT X,Y TO X,Y+4 TO X+5,Y+4: HPLOT X+5,Y TO X+5,Y+8: RETURN
7150 IF DD = 5 THEN HPLOT X+5,Y TO X,Y TO X,Y+4 TO X+5,Y+4 TO X+5,Y+8 TO X,Y+8: RETURN
7160 IF DD = 6 THEN HPLOT X+5,Y TO X,Y TO X,Y+8 TO X+5,Y+8 TO X+5,Y+4 TO X,Y+4: RETURN
7170 IF DD = 7 THEN HPLOT X,Y TO X+5,Y TO X+5,Y+8: RETURN
7180 IF DD = 8 THEN HPLOT X,Y TO X+5,Y TO X+5,Y+8 TO X,Y+8 TO X,Y: HPLOT X,Y+4 TO X+5,Y+4: RETURN
7190 IF DD = 9 THEN HPLOT X+5,Y+4 TO X,Y+4 TO X,Y TO X+5,Y TO X+5,Y+8: RETURN
7199 RETURN

7500 HPLOT X,Y TO X+10,Y: HPLOT X+5,Y TO X+5,Y+10 TO X,Y+10 TO X,Y+8: RETURN
7600 HPLOT X,Y TO X+10,Y TO X+10,Y+10 TO X,Y+10 TO X,Y: RETURN

8000 IF G = 1 THEN POKE 230, 32: RETURN
8010 POKE 230, 64: RETURN

9000 DIM LH(5,6), LV(6,5), BX(5,5)
9010 PS = 0: OS = 0: TR = 0: MD = 0: BT = 0: FI = 0: BL = 0: CP = 1
9020 RETURN
